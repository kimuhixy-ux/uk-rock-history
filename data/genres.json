{
  "categories": [
    {
      "id": "british-invasion",
      "label": "ブリティッシュ・インヴェイジョン / マージービート",
      "period": "1960s",
      "description": "リヴァプールのマージービートを中心に、アメリカ市場を席巻したビートバンド群。"
    },
    {
      "id": "blues-rock",
      "label": "ブルースロック",
      "period": "1960s",
      "description": "アメリカのブルースを英国の若者がロックとして再解釈したジャンル。"
    },
    {
      "id": "psychedelic-rock",
      "label": "サイケデリックロック",
      "period": "1960s",
      "description": "幻覚的・実験的なサウンドを追求したロック。"
    },
    {
      "id": "progressive-rock",
      "label": "プログレッシブロック",
      "period": "1970s",
      "description": "クラシックやジャズの語法を取り込み、組曲的な長尺曲を志向したロック。"
    },
    {
      "id": "hard-rock",
      "label": "ハードロック",
      "period": "1970s",
      "description": "歪んだギターと強靭なリズムを前面に押し出したロック。"
    },
    {
      "id": "heavy-metal",
      "label": "ヘヴィメタル(NWOBHM含む)",
      "period": "1970s-1980s",
      "description": "ハードロックからさらに攻撃性を増したジャンル。NWOBHM(新世紀英国重金属)を含む。"
    },
    {
      "id": "glam-rock",
      "label": "グラムロック",
      "period": "1970s",
      "description": "派手な化粧・衣装とポップなロックサウンドを組み合わせたジャンル。"
    },
    {
      "id": "punk-rock",
      "label": "パンクロック",
      "period": "1970s",
      "description": "過剰技巧化したロックへの反発として生まれた、シンプルで攻撃的なロック。"
    },
    {
      "id": "post-punk-new-wave",
      "label": "ポストパンク / ニューウェイヴ",
      "period": "1970s-1980s",
      "description": "パンクの精神を保ちつつ、より実験的・電子的な方向へ発展したジャンル。"
    },
    {
      "id": "gothic-rock",
      "label": "ゴシックロック",
      "period": "1980s",
      "description": "ポストパンクから派生した、陰鬱で耽美的な世界観を持つロック。"
    },
    {
      "id": "madchester",
      "label": "マッドチェスター",
      "period": "1980s-1990s",
      "description": "マンチェスターを中心に、ダンスミュージックとロックが融合したムーブメント。"
    },
    {
      "id": "shoegaze",
      "label": "シューゲイザー",
      "period": "1980s-1990s",
      "description": "ノイジーなギターの壁とドリーミーなヴォーカルが特徴のジャンル。"
    },
    {
      "id": "britpop",
      "label": "ブリットポップ",
      "period": "1990s",
      "description": "英国性を強く打ち出したギターポップ/ロックのムーブメント。"
    },
    {
      "id": "alternative-indie",
      "label": "オルタナティブ / インディーロック",
      "period": "1990s-2000s",
      "description": "メインストリームから距離を置いた、独立系のロックサウンド。"
    },
    {
      "id": "other",
      "label": "その他(フォークロック、パブロック等)",
